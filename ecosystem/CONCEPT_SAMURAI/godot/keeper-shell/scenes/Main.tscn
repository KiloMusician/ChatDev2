[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/main.gd" id="1_main"]
[ext_resource type="Script" path="res://scripts/keeper_bridge.gd" id="2_bridge"]
[ext_resource type="Texture2D" path="res://assets/icon.svg" id="3_icon"]

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_main")

[node name="KeeperBridge" type="Node" parent="."]
script = ExtResource("2_bridge")

[node name="TrayMenu" type="PopupMenu" parent="."]

[node name="Tray" type="StatusIndicator" parent="."]
icon = ExtResource("3_icon")
tooltip = "Keeper Shell"
visible = true

[node name="RefreshTimer" type="Timer" parent="."]
wait_time = 8.0
autostart = true

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="Root" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Hero" type="PanelContainer" parent="Margin/Root"]
layout_mode = 2

[node name="HeroBox" type="VBoxContainer" parent="Margin/Root/Hero"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="Title" type="Label" parent="Margin/Root/Hero/HeroBox"]
layout_mode = 2
text = "Keeper Shell"
theme_override_font_sizes/font_size = 26

[node name="Subtitle" type="Label" parent="Margin/Root/Hero/HeroBox"]
layout_mode = 2
text = "Offline-first desktop shell for keeper. Uses the local PowerShell bridge; no network required."
autowrap_mode = 2

[node name="StatusGrid" type="GridContainer" parent="Margin/Root"]
layout_mode = 2
columns = 4

[node name="ModeCard" type="PanelContainer" parent="Margin/Root/StatusGrid"]
layout_mode = 2

