# Terminal Depths / Lattice Ecosystem — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────
# Usage:
#   cp .env.example .env
#   # edit .env with your real values, then:
#   make docker-core                  # shared singleton infra
#   make docker-up                    # + shared ops (MCP, LM Studio bridge, n8n)
#   make docker-apps                  # + optional app containers
#   make docker-sidecars              # + legacy all-container sidecars
#   make docker-full                  # legacy showcase stack
#
# Where values are read:
#   Docker        → env_file: .env (docker-compose.yml)
#   Replit        → Secrets panel (takes precedence over .env)
#   VSCode local  → .env auto-loaded by devcontainer, or: export $(cat .env | xargs)
#   direnv        → add to .envrc: dotenv .env
# ─────────────────────────────────────────────────────────────────────────

# ── Core API endpoints ────────────────────────────────────────────────────
# Terminal Depths / DevMentor API
#   Replit native  → port 5000 (auto-detected via REPL_ID env var)
#   Docker / VSCode / local → port 7337 (default)
TERMINAL_DEPTHS_URL=http://localhost:7337
TD_BASE_URL=http://localhost:7337
PORT=7337

# ── Auth ─────────────────────────────────────────────────────────────────
# REQUIRED in Docker / VSCode. In Replit, set via the Secrets panel.
SESSION_SECRET=change-me-to-a-long-random-string-in-production

# ── Redis pub/sub backbone ────────────────────────────────────────────────
# Docker (service name): redis://redis:6379
# Local host:            redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Ollama local LLM ─────────────────────────────────────────────────────
# Docker (service name): http://ollama:11434
# Local host:            http://localhost:11434
# Docker host from container: http://host.docker.internal:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── Model Router ─────────────────────────────────────────────────────────
MODEL_ROUTER_URL=http://localhost:9001
USE_ROUTER=0
MODEL_ROUTER_OLLAMA_MODEL=qwen2.5-coder:14b

# ── Replit AI Integration (Replit-managed — do NOT set manually in Replit) ──
# In Docker/VSCode these can be pointed at any OpenAI-compatible endpoint.
# AI_INTEGRATIONS_OPENAI_BASE_URL=http://localhost:1106/modelfarm/openai
# AI_INTEGRATIONS_OPENAI_API_KEY=your-replit-or-openai-key

# ── OpenAI (optional — GPT-4 fallback in LLM router) ─────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic (optional — Claude fallback) ───────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ── GitHub ───────────────────────────────────────────────────────────────
# Required for:  entrypoint.sh repo harvest, gordon push, git commands in-game
# Scope needed:  repo (read+write) or repo:read for harvest only
# GITHUB_TOKEN=ghp_...

# ── Gordon player agent ───────────────────────────────────────────────────
# Override the game API for gordon_player.py.
# Leave blank → auto-discovers from REPLIT_DEV_DOMAIN or defaults to localhost:7337
GORDON_GAME_API=
# Set to host.docker.internal when Gordon runs inside Docker and needs the host.
GORDON_DOCKER_HOST=

# ── Serena / SkyClaw ─────────────────────────────────────────────────────
SERENA_DB=state/serena_memory.db
SERENA_REPO_ROOT=/app

# ── Repo harvest (entrypoint.sh) ─────────────────────────────────────────
# Set SKIP_HARVEST=1 to skip cloning ecosystem repos at startup (faster dev loop)
SKIP_HARVEST=0
REPOS_DIR=/workspace/repos

# ── PostgreSQL (shared singleton) ────────────────────────────────────────
POSTGRES_PASSWORD=terminal_depths_secure

# ── n8n workflow automation ───────────────────────────────────────────────
N8N_PASSWORD=n8n_secure

# ── Jupyter Lab (docker-compose.full.yml) ────────────────────────────────
JUPYTER_TOKEN=terminal_depths_token

# ── Workspace / paths ────────────────────────────────────────────────────
WORKSPACE_ROOT=/app
NUSYQ_HUB_PATH=/workspace/repos/NuSyQ-Hub
SIMULATED_VERSE_PATH=/workspace/repos/SimulatedVerse
NUSYQ_ULTIMATE_PATH=/workspace/repos/NuSyQ-Ultimate
NUSYQ_HUB_ROOT=../Desktop/Legacy/NuSyQ-Hub
SIMULATEDVERSE_ROOT=../Desktop/SimulatedVerse/SimulatedVerse

# ── LM Studio bridge ──────────────────────────────────────────────────────
LM_STUDIO_HOST=host.docker.internal
LM_STUDIO_PORT=1234

# ── Auto-sleep (Replit only — keeps free Repl awake) ─────────────────────
AUTO_SLEEP_MINUTES=120
