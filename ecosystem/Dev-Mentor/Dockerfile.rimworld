# ════════════════════════════════════════════════════════════════════════════════
# RimWorld VNC Container
# Runs the Linux version of RimWorld inside a container with:
#   - Xvfb (virtual framebuffer)
#   - x11vnc (VNC server)
#   - noVNC (web-based VNC client on port 6080)
#   - Terminal Keeper mod pre-mounted
#
# The game files are expected in /rimworld/game (via volume mount).
# ════════════════════════════════════════════════════════════════════════════════

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV DISPLAY=:1

# Core dependencies
RUN apt-get update && apt-get install -y \
    xvfb \
    x11vnc \
    novnc \
    websockify \
    openbox \
    curl \
    python3 \
    python3-pip \
    wget \
    libglu1-mesa \
    libxrandr2 \
    libxext6 \
    libxfixes3 \
    libxi6 \
    libxrender1 \
    libxss1 \
    libxtst6 \
    libasound2 \
    && rm -rf /var/lib/apt/lists/*

# Marker so scripts can detect container environment
RUN touch /.terminal-keeper-container

# noVNC web interface
RUN ln -sf /usr/share/novnc/vnc.html /usr/share/novnc/index.html

# Helper scripts
COPY scripts/rimworld_entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# VNC password (overridden by env at runtime)
RUN mkdir -p /root/.vnc && x11vnc -storepasswd lattice /root/.vnc/passwd

EXPOSE 5900 6080

ENTRYPOINT ["/entrypoint.sh"]
