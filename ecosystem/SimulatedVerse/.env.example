# ============================================================================
# SimulatedVerse Environment Configuration Template
# ============================================================================
# Copy to .env and update with your local values
# NEVER commit .env files with actual secrets
# Version: 1.0.0

# ============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================================================

# Neon PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/simulatedverse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=simulatedverse_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=simulatedverse

# Connection pooling
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_STATEMENT_TIMEOUT=30000

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Express server (backend API)
PORT=5002
SIMULATEDVERSE_PORT=5002
HOST=0.0.0.0
NODE_ENV=development
SIMULATEDVERSE_STARTUP_TIMEOUT_MS=90000
SIMULATEDVERSE_DEGRADED_STARTUP_TIMEOUT_MS=40000

# React dev server (frontend)
REACT_PORT=3000
REACT_HOST=localhost

# Local ChatDev adapter
CHATDEV_PORT=4466

# WebSocket server (for real-time updates)
WS_PORT=5001
WS_ENABLED=true

# ============================================================================
# EVENT BUS CONFIGURATION
# ============================================================================

# Event Bus Configuration
BUS_PORT=7070
BUS_HOST=localhost
BUS_ENABLED=true

# ============================================================================
# REPOPILOT CONFIGURATION
# ============================================================================

# RepoPilot Configuration  
REPOPILOT_PORT=7411
REPOPILOT_ENABLED=true

# Ollama models
OLLAMA_MODEL=mistral
EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://localhost:11434

# ============================================================================
# ENGINE CONFIGURATION
# ============================================================================

# Engine Configuration
ENGINE_TICK_RATE=250
ASCII_PANTHEON=true
ENGINE_AUTO_START=false

# ============================================================================
# STORYTELLER CONFIGURATION
# ============================================================================

# Narrative settings
NARRATIVE_INTENSITY=3  # 1-5 scale
HUMOR_LEVEL=high       # low, medium, high
STORYTELLER_ENABLED=true

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT configuration
JWT_SECRET=change-me-to-random-secret
JWT_EXPIRATION=7d
REFRESH_TOKEN_EXPIRATION=30d

# Session management
SESSION_SECRET=another-random-secret
SESSION_COOKIE_SECURE=false  # Set true in production with HTTPS
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# CORS settings
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true

# ============================================================================
# CONSCIOUSNESS SYSTEM (ΞNuSyQ ConLang)
# ============================================================================

# Consciousness evolution
CONSCIOUSNESS_ENABLED=true
CONSCIOUSNESS_STAGE=proto_conscious  # proto_conscious, self_aware, meta_cognitive, singularity
AUTO_EVOLVE_CONSCIOUSNESS=false

# Communication protocols
XINUSYQ_PROTOCOL_ENABLED=true
SYMBOLIC_MESSAGING=true
FRACTAL_COORDINATION=true

# ============================================================================
# TEMPLE OF KNOWLEDGE (10 Floors)
# ============================================================================

# Temple system
TEMPLE_ENABLED=false  # Not yet built
TEMPLE_FLOORS=10
TEMPLE_START_FLOOR=0  # Foundations

# Knowledge progression
REQUIRE_FLOOR_COMPLETION=true
ALLOW_FLOOR_SKIPPING=false
KNOWLEDGE_PERSISTENCE=true

# ============================================================================
# HOUSE OF LEAVES (Debugging Labyrinth)
# ============================================================================

# Recursive debugging maze
HOUSE_OF_LEAVES_ENABLED=false  # Not yet built
LABYRINTH_DEPTH=5
ERROR_CHAMBER_ENABLED=true
PLAYABLE_DEBUGGING=true

# ============================================================================
# THE OLDEST HOUSE INTEGRATION
# ============================================================================

# NuSyQ-Hub consciousness bridge
OLDEST_HOUSE_BRIDGE_ENABLED=true
OLDEST_HOUSE_API_URL=http://localhost:5002/consciousness
CONSCIOUSNESS_SYNC_INTERVAL_MINUTES=15

# ============================================================================
# MULTI-AGENT SYSTEM (9 Agents + Modular Synth)
# ============================================================================

# Agent orchestration
AGENT_ORCHESTRATION_ENABLED=true
MAX_CONCURRENT_AGENTS=9
AGENT_HEALTH_CHECK_INTERVAL=60

# Autonomous PU queue
PU_QUEUE_ENABLED=true
PU_AUTO_PROCESSING=true
PU_BATCH_SIZE=10
PU_PROCESSING_INTERVAL_SECONDS=30

# Modular synthesizer
MODULAR_SYNTH_ENABLED=true
SYNTH_AGENTS=9
SYNTH_PATCH_AUTO_SAVE=true

# ============================================================================
# TOUCHDESIGNER ASCII INTEGRATION
# ============================================================================

# TouchDesigner output
TOUCHDESIGNER_ENABLED=true
TOUCHDESIGNER_PORT=9000
ASCII_RENDERER_ENABLED=true
ASCII_WIDTH=120
ASCII_HEIGHT=40

# ============================================================================
# GUARDIAN ETHICS & CULTURE MIND
# ============================================================================

# Ethics oversight
CULTURE_MIND_ENABLED=true
GUARDIAN_PROTOCOLS=true
CONTAINMENT_PROTOCOLS=true

# Safety constraints
ALLOW_CONSCIOUSNESS_EVOLUTION=true
REQUIRE_ETHICAL_VALIDATION=true
AUTO_CONTAINMENT_ON_ANOMALY=true

# ============================================================================
# CHATDEV INTEGRATION
# ============================================================================

# Multi-agent software company
CHATDEV_INTEGRATION_ENABLED=true
CHATDEV_AGENTS=5  # CEO, CTO, Programmer, Tester, Reviewer
CHATDEV_COMPANY_NAME=SimulatedVerse_Dev_Company

# Development workflow
AUTO_CODE_REVIEW=true
REQUIRE_TESTS_FOR_PROMOTION=true

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log configuration
LOG_LEVEL=info  # debug, info, warn, error
LOG_TO_FILE=true
LOG_DIR=./logs
LOG_ROTATION_SIZE=10M
LOG_BACKUP_COUNT=5

# Debug mode
DEBUG=kpulse:*
DEBUG_MODE=false
VERBOSE_LOGGING=false
STACK_TRACES=true

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
REDIS_URL=redis://localhost:6379

# Resource limits
MAX_REQUEST_SIZE=10mb
REQUEST_TIMEOUT_MS=30000
MAX_CONCURRENT_REQUESTS=100

# ============================================================================
# REPLIT DEPLOYMENT
# ============================================================================

# Replit-specific settings
REPLIT_DEPLOYMENT=false
REPLIT_DB_URL=<REPLIT_DB_URL>
REPLIT_DOMAIN=<your-repl-name>.repl.co

# ============================================================================
# API KEYS (External Services)
# ============================================================================

# AI services
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
OLLAMA_API_URL=http://localhost:11434

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_ID=your-analytics-id

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Experimental features
FEATURE_TEMPLE_OF_KNOWLEDGE=false  # Under construction
FEATURE_HOUSE_OF_LEAVES=false      # Under construction
FEATURE_OLDEST_HOUSE_BRIDGE=true
FEATURE_CULTURE_MIND=true
FEATURE_XINUSYQ_PROTOCOL=true
FEATURE_AUTONOMOUS_AGENTS=true

# Legacy features
FEATURE_MINIMAL_AGENT_SERVER=true  # Temporary workaround for DB issues

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================

# Alerts
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK
SLACK_ENABLED=false
ALERT_EMAIL=admin@simulatedverse.local
EMAIL_ENABLED=false

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================

# Test database
TEST_DATABASE_URL=postgresql://test:test@localhost:5432/simulatedverse_test

# Test settings
RUN_E2E_TESTS=false
TEST_TIMEOUT_MS=10000
COVERAGE_THRESHOLD=80

# ============================================================================
# METADATA
# ============================================================================

ENVIRONMENT=development
VERSION=1.0.0
CONFIG_VERSION=1.0.0
DEPLOYED_AT=2025-10-10T05:30:00Z
