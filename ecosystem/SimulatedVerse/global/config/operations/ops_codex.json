{
  "version": "1.0",
  "budgets": {
    "daily_token_limit": 120000,
    "per_task_soft_cap": 2500,
    "per_task_hard_cap": 5000,
    "api_escalation_min_conf": 0.62,
    "api_escalation_min_info_gain": 0.18
  },
  "models": {
    "local_primary": "ollama://qwen2.5:7b-instruct-q4_K_M",
    "local_judge": "ollama://llama3.1:8b-instruct-q4_K_M",
    "distilled_aux": "ollama://phi3:mini-instruct",
    "paid_fallback": "openai://gpt-4o-mini"
  },
  "caching": {
