{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development TMPDIR=/tmp node --env-file=.env --import tsx/esm server/index.ts",
    "dev:full": "cross-env NODE_ENV=development TMPDIR=/tmp PORT=5002 SIMULATEDVERSE_PORT=5002 node --env-file=.env --import tsx/esm server/index.ts",
    "dev:minimal": "cross-env NODE_ENV=development TMPDIR=/tmp PORT=5002 SIMULATEDVERSE_PORT=5002 node --env-file=.env --import tsx/esm server/minimal_server.ts",
    "dev:degraded": "cross-env NODE_ENV=development TMPDIR=/tmp PORT=5002 SIMULATEDVERSE_PORT=5002 node --env-file=.env --import tsx/esm server/minimal_server.ts",
    "dev:fallback": "cross-env NODE_ENV=development TMPDIR=/tmp PORT=5002 SIMULATEDVERSE_PORT=5002 node --env-file=.env --import tsx/esm server/startup_fallback.ts",
    "surfaces:ensure": "bash ops/ensure-local-surfaces.sh",
    "ops:health": "bash ops/health-checks.sh",
    "culture-ship:describe": "python3 ops/export_culture_ship_runtime_descriptor.py",
    "quest-log:rotate": "python3 ops/rotate_shared_quest_log.py",
    "quest-log:rotate:apply": "python3 ops/rotate_shared_quest_log.py --apply",
    "git:doctor": "bash ops/git-boundary-check.sh",
    "chatdev:health": "npx --yes tsx ops/chatdev/health.ts",
    "chatdev:smoke": "bash ops/chatdev/smoketest.sh",
    "docs:gen": "node scripts/generate-docs.cjs",
    "devshell": "node tools/devshell/server.mjs",
    "open:rescue": "node -e \"console.log('Open http://localhost:3030 after devshell starts')\"",
    "hud:rescue": "bash -lc 'npm run devshell >/tmp/simulatedverse-devshell.log 2>&1 & sleep 1; npm run open:rescue'",
    "ml:curate": "bash -lc 'mkdir -p ml/data/snapshots && python3 scripts/ml_scan.py . > ml/data/snapshots/ml_inventory.json && echo ml/data/snapshots/ml_inventory.json'",
    "ml:eval": "python3 scripts/ml_value_map.py",
    "build": "vite build && esbuild server/index.ts server/full_server.ts server/minimal_server.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "test": "vitest run --config vitest.config.ts",
    "rehydration:harness": "tsx server/utils/rehydration_harness.ts",
    "ci": "npm run check && npm run lint:errors && npm run test",
    "rehydrate:harness": "npx --yes tsx server/utils/rehydration_harness.ts",
    "test:persisted-circuits": "npx --yes tsx server/utils/test_persisted_circuits_no_functions.ts",
    "test:integration-repair": "npx --yes tsx server/utils/integration_test_repair.ts",
    "check:terminals": "npx --yes tsx server/utils/check_terminals.ts",
    "test:smart-search": "npx --yes tsx packages/ludic/test_lore_search.ts",
    "test:token-governor": "npx --yes tsx modules/culture_ship/planners/test_token_governor.ts",
    "test:subsystems": "npm run test:smart-search && npm run test:token-governor",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "agents": "npx tsx ops/activate-agents.ts",
    "agents:watch": "npx tsx ops/activate-agents.ts && npx tsx ops/nusyq-bridge.ts",
    "bridge": "npx tsx ops/nusyq-bridge.ts",
    "bridge:once": "npx tsx ops/nusyq-bridge.ts --once",
    "chug": "npx tsx ops/chug-runner.ts",
    "lint": "npx eslint server/ client/src/ --max-warnings 9999",
    "lint:errors": "npx eslint server/ client/src/",
    "audit": "npm run check && npm run lint:errors",
    "check:all": "npm run check && npm run lint:errors && echo ALL_CLEAN",
    "seed": "node --env-file=.env --import tsx/esm ops/seed-raven.ts",
    "raven": "node --env-file=.env --import tsx/esm ops/raven-runner.ts",
    "activate": "concurrently --kill-others-on-fail -n srv,raven -c cyan,yellow \"npm run dev\" \"npm run raven\""
  },
