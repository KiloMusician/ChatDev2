{
  "include": ["client/src/**/*", "shared/**/*", "server/**/*", "src/**/*"],
  "exclude": ["node_modules", "build", "dist", "**/*.test.ts"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "./node_modules/typescript/tsbuildinfo",
    "noEmit": true,
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"],
      "#shared/*": ["./shared/*"],
      "#server/*": ["./server/*"],
      "#ai/*": ["./ai-systems/*"],
      "#sys/*": ["./system/*"],
      "#src/*": ["./src/*"],
      "@game/*": ["./GameDev/*"],
      "@engine/*": ["./GameDev/engine/*"],
      "@play/*": ["./GameDev/gameplay/*"],
      "@systems/*": ["./GameDev/systems/*"],
      "@content/*": ["./GameDev/content/*"],
      "@chat/*": ["./ChatDev/*"],
      "@agents/*": ["./ChatDev/agents/*"],
      "@msgx/*": ["./ChatDev/directives/MsgX/*"],
      "@rsev/*": ["./ChatDev/directives/RSEV/*"],
      "@sys/*": ["./SystemDev/*"],
      "@scripts/*": ["./SystemDev/scripts/*"],
      "@knowledge/*": ["./knowledge/*"],
      "@ui/*": ["./PreviewUI/*"],
      "@mobile/*": ["./PreviewUI/mobile/*"],
      "@sectors/*": ["./Sectors/*"]
    }
  }
}
