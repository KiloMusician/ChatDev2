#!/usr/bin/env bash
set -Eeuo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PATH="$ROOT/node_modules/.bin:$PATH"

LOG(){ printf "\n\033[1;36m[rif]\033[0m %s\n" "$*"; }
OK(){  printf "\033[1;32m✔\033[0m %s\n" "$*"; }
WARN(){ printf "\033[1;33m⚠\033[0m %s\n" "$*"; }
ERR(){ printf "\033[1;31m✖\033[0m %s\n" "$*"; }

ensure_node() { if ! command -v node >/dev/null; then ERR "node missing"; exit 0; fi; }
ensure_pnpm() { if ! command -v pnpm >/dev/null; then LOG "install pnpm"; npm i -g pnpm@9 || true; fi; }

boot(){
  LOG "Boot… doctor + cache warm"
  ensure_node; ensure_pnpm
  pnpm i --frozen-lockfile=false || pnpm i || npm install
  bash scripts/rif doctor || true
  bash scripts/rif plan:fast || true
  OK "Boot complete"
}

doctor(){
  LOG "Doctor: quick checks"
  fd -u -H -t f -E node_modules -E .git > .cache/filelist.txt || find . -type f > .cache/filelist.txt 2>/dev/null || true
  rg -n "TODO|FIXME|XXX" || grep -rn "TODO\|FIXME\|XXX" . || true
  OK "Doctor done"
}

dev:web(){
  LOG "Dev Web (mobile/desktop adaptive)"
  export VITE_VIEW_AUTO="1"
  npm run dev || pnpm dev:web || node server/index.mjs
}

dev:tui(){
  LOG "TUI Cockpit (ASCII HUD)"
  node packages/ascii-hud/index.mjs
}

start(){
  LOG "Start production server"
  npm run build || pnpm build || true
  npm run start || pnpm start || node server/index.mjs
}

test(){ LOG "Tests"; npm test || pnpm test || true; }

lint(){ LOG "Lint"; npm run lint || pnpm lint || true; }

fmt(){ LOG "Format"; npm run fmt || pnpm fmt || npx prettier -w . || true; }

plan:fast(){
  LOG "Cascade micro-plan (zero-token)"
  python3 engine/cascade_event.py --mode=micro --no-llm || python cascade_boot.py || true
}

cascade(){
  LOG "Cascade plan & execute (budget-aware)"
  python3 engine/cascade_event.py --mode=full --maybe-llm || python ascension_form_boot.py || true
}

setup(){
  LOG "Setup repo defaults"
  chmod +x scripts/rif
  mkdir -p .github/workflows engine config packages/ascii-hud server app public .cache docs/temple docs/house docs/oldest
  cp -n templates/ci.yml .github/workflows/ci.yml 2>/dev/null || true
  cp -n templates/vite.config.mjs vite.config.mjs 2>/dev/null || true
  OK "Setup complete"
}

sync:gh(){
  LOG "Mirror to GitHub"
  git add -A
  git commit -m "rif: mirror" || true
  git push origin HEAD || true
  OK "Sync complete"
}

case "${1:-help}" in
  boot|doctor|dev:web|dev:tui|start|test|lint|fmt|plan:fast|cascade|setup|sync:gh) "$@";;
  *) LOG "Usage: rif [boot|doctor|dev:web|dev:tui|start|test|lint|fmt|plan:fast|cascade|setup|sync:gh]";;
esac