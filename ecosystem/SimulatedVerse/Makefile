        pnpm -w -r --parallel dev

bus:
        node apps/engine/scripts/bus.js

lint:
        pnpm -w -r lint

test:
        pnpm -w -r test

analyze:
        jupyter lab --notebook-dir=analysis

docs-sync:
        git add kb && git commit -m "docs(kb): sync" || true
        git push

ui-audit:
        node scripts/ui-audit.js

schema-validate:
        node scripts/schema-validate.js

# Token discipline shortcuts
smoke-test:
        tsx sidecar/smoke_test.ts

auto-refactor:
        tsx agent/auto_refactor.ts

token-stats:
        tsx -e "import {getBudgetStatus} from './sidecar/token_guard.js'; console.log(getBudgetStatus())"

# Cost containment modes
dev-hard:
        BUDGET_MODE=hard CONTEXT_MAX=1500 pnpm dev

dev-cache:
        CACHE_ONLY=1 pnpm dev

dev-trace:
        TRACE_SAMPLING=1.0 DEBUG=kpulse:* pnpm dev

# Quick AI assistance
ai:
        @if [ -z "$(q)" ]; then echo "Usage: make ai q='your question'"; exit 1; fi
        @curl -s http://localhost:7411/ask -H "Content-Type: application/json" -d "{\"q\":\"$(q)\"}" | jq -r .answer

patch:
        @if [ -z "$(goal)" ]; then echo "Usage: make patch goal='implement feature'"; exit 1; fi
        @curl -s http://localhost:7411/patch -H "Content-Type: application/json" -d "{\"goal\":\"$(goal)\"}" | jq -r .diff

# Query-Quest: ultra-low-token system audit
qquest: ## Run Query-Quest with minimal LLM probes
        @echo "Running Query-Quest (full analysis)..."
        @bash tools/qquest.sh .
        @echo "Probing top 10 risky files with LLM..."
        @awk -F: 'NR<=10{print $$1}' .qquest/placeholders_and_spinloops.txt | cut -d: -f1 | sort -u | head -n 10 \
        | while read f; do \
                [ -f "$$f" ] && bash tools/llm_probe.sh tools/prompts/triage.prompt "$$f" || true; \
        done
        @echo "Query-Quest analysis complete! Check .qquest/ for reports"

qquest-fast: ## Run Query-Quest static analysis only (no LLM)
        @echo "Running Query-Quest (static only)..."
        @bash tools/qquest.sh .
        @echo "Static analysis complete! Check .qquest/ for reports"

setup-tools: ## Install Query-Quest dependencies
        @echo "Installing Query-Quest tools..."
        @command -v brew >/dev/null && brew install ripgrep fd hadolint shellcheck || echo "brew not found, skipping brew packages"
        @pip install --upgrade pip
        @pip install ruff mypy bandit safety pip-audit rich-click radon deptry
        @npm i -g eslint typescript @typescript-eslint/parser @typescript-eslint/eslint-plugin
        @command -v pre-commit >/dev/null && pre-commit install || pip install pre-commit && pre-commit install
        @echo "Query-Quest tools ready!"

