# ============================================================================
# NuSyQ Root Environment Configuration Template
# ============================================================================
# Multi-AI Environment with 14 Agents + 37.5GB Ollama Models
# Copy to .env and update with your local values
# Version: 1.0.0

# ============================================================================
# OLLAMA CONFIGURATION (37.5GB Models)
# ============================================================================

# Ollama server
OLLAMA_HOST=http://localhost:11434
OLLAMA_API_KEY=not-required-for-local
OLLAMA_MODELS_PATH=~/.ollama/models

# Default models (37.5GB collection)
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_MODELS=qwen2.5-coder:7b,starcoder2:7b,gemma2:9b,deepseek-coder:6.7b,codellama:13b,mistral:7b,llama3:8b

# Model settings
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_P=0.9
OLLAMA_MAX_TOKENS=4096
OLLAMA_TIMEOUT_SECONDS=300

# ============================================================================
# CHATDEV CONFIGURATION (5 Agents)
# ============================================================================

# ChatDev company
CHATDEV_PATH=C:/Users/keath/NuSyQ/ChatDev
CHATDEV_ENABLED=true
CHATDEV_COMPANY_NAME=NuSyQ_Software_Company

# ChatDev agents (CEO, CTO, Programmer, Tester, Reviewer)
CHATDEV_AGENTS=5
CHATDEV_DEFAULT_MODEL=qwen2.5-coder:7b
CHATDEV_USE_OLLAMA=true

# Development settings
CHATDEV_AUTO_START=false
CHATDEV_WORKSPACE=./ChatDev/WareHouse
CHATDEV_LOG_DIR=./ChatDev/logs

# ============================================================================
# MCP SERVER (Model Context Protocol)
# ============================================================================

# MCP server configuration
MCP_SERVER_ENABLED=true
MCP_SERVER_PORT=8080
MCP_SERVER_HOST=localhost

# Agent coordination
MCP_MAX_AGENTS=14
MCP_COORDINATION_PROTOCOL=xinusyq
MCP_HEARTBEAT_INTERVAL_SECONDS=30

# ============================================================================
# AGENT ORCHESTRATION (14 Total Agents)
# ============================================================================

# Agent types:
# - Claude Code (1)
# - Ollama (7 models)
# - ChatDev (5 roles)
# - GitHub Copilot (1)
# - Continue.dev (1)

# Orchestration settings
AGENT_ORCHESTRATOR_ENABLED=true
MAX_CONCURRENT_AGENTS=14
AGENT_TASK_QUEUE_SIZE=100
AGENT_RETRY_ATTEMPTS=3

# Load balancing
LOAD_BALANCER_ENABLED=true
ROUND_ROBIN_SCHEDULING=true
AGENT_HEALTH_CHECK_INTERVAL=60

# ============================================================================
# CLAUDE CODE CONFIGURATION
# ============================================================================

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=8192

# ============================================================================
# GITHUB COPILOT CONFIGURATION
# ============================================================================

# GitHub Copilot
GITHUB_TOKEN=your-github-personal-access-token
COPILOT_ENABLED=true
COPILOT_SUGGESTIONS=true

# ============================================================================
# CONTINUE.DEV CONFIGURATION
# ============================================================================

# Continue.dev local LLM integration
CONTINUE_ENABLED=true
CONTINUE_CONFIG_PATH=~/.continue/config.json
CONTINUE_DEFAULT_MODEL=qwen2.5-coder:7b

# ============================================================================
# XINUSYQ PROTOCOL (Symbolic Messaging)
# ============================================================================

# ΞNuSyQ conlang for multi-agent coordination
XINUSYQ_ENABLED=true
SYMBOLIC_COMPRESSION=true
FRACTAL_MESSAGE_FORMAT=true

# Protocol settings
XINUSYQ_MESSAGE_TTL_SECONDS=3600
XINUSYQ_BROADCAST_ENABLED=true
XINUSYQ_ENCRYPTION=false

# ============================================================================
# JUPYTER LAB CONFIGURATION
# ============================================================================

# Jupyter server
JUPYTER_ENABLED=true
JUPYTER_PORT=8888
JUPYTER_DIR=./Jupyter
JUPYTER_TOKEN=change-me

# Notebook settings
JUPYTER_AUTO_START=false
JUPYTER_ALLOW_ROOT=false

# ============================================================================
# KNOWLEDGE BASE
# ============================================================================

# Knowledge persistence
KNOWLEDGE_BASE_PATH=./knowledge-base.yaml
KNOWLEDGE_AUTO_SAVE=true
KNOWLEDGE_BACKUP_INTERVAL_HOURS=24

# Learning settings
AUTO_LEARN_FROM_TASKS=true
LEARNING_RATE=0.01
KNOWLEDGE_RETENTION_DAYS=365

# ============================================================================
# REPOSITORY PATHS
# ============================================================================

# Multi-repository workspace
NUSYQ_ROOT=C:/Users/keath/NuSyQ
NUSYQ_HUB_ROOT=C:/Users/keath/Desktop/Legacy/NuSyQ-Hub
SIMULATEDVERSE_ROOT=C:/Users/keath/Desktop/SimulatedVerse/SimulatedVerse
CHATDEV_ROOT=C:/Users/keath/NuSyQ/ChatDev

# ============================================================================
# TASK COORDINATION
# ============================================================================

# Task queue
TASK_QUEUE_ENABLED=true
TASK_QUEUE_TYPE=redis  # redis, memory, postgres
REDIS_URL=redis://localhost:6379/0

# Task execution
MAX_PARALLEL_TASKS=5
TASK_TIMEOUT_SECONDS=600
AUTO_RETRY_FAILED_TASKS=true

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DIR=./Logs
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
LOG_ROTATION_MAX_MB=10
LOG_BACKUP_COUNT=5

# Debug mode
DEBUG_MODE=false
VERBOSE_AGENT_LOGS=false
TRACE_AGENT_CALLS=false

# ============================================================================
# PERFORMANCE OPTIMIZATION
# ============================================================================

# Caching
CACHE_ENABLED=true
CACHE_DIR=./State/cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE_MB=500

# Parallel processing
MAX_WORKERS=8
ENABLE_MULTIPROCESSING=true
ASYNC_AGENT_CALLS=true

# Memory management
MAX_MEMORY_MB=8192
MEMORY_WARNING_THRESHOLD_MB=6144

# ============================================================================
# COST TRACKING (Offline-First = $880/year savings)
# ============================================================================

# API usage tracking
TRACK_API_COSTS=true
COST_ALERTS_ENABLED=true
MONTHLY_BUDGET_USD=100

# Offline-first settings
PREFER_LOCAL_MODELS=true
OLLAMA_FIRST_STRATEGY=true
CLOUD_API_FALLBACK=true

# ============================================================================
# KUBERNETES & DEPLOYMENT (Optional)
# ============================================================================

# K8s deployment
KUBERNETES_ENABLED=false
K8S_NAMESPACE=nusyq
K8S_REPLICA_COUNT=3

# Container settings
DOCKER_ENABLED=false
CONTAINER_REGISTRY=ghcr.io/nusyq

# ============================================================================
# SECURITY
# ============================================================================

# Encryption
SECRET_KEY=change-me-to-random-64-char-string
ENCRYPTION_ALGORITHM=AES-256-GCM

# API security
API_RATE_LIMIT=100  # requests per minute
REQUIRE_API_KEY=false
API_KEY=your-api-key

# ============================================================================
# NOTIFICATION SETTINGS
# ============================================================================

# Slack
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK
SLACK_ENABLED=false
SLACK_CHANNEL=#nusyq-alerts

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
EMAIL_ENABLED=false

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Experimental features
FEATURE_CHATDEV_INTEGRATION=true
FEATURE_MCP_SERVER=true
FEATURE_XINUSYQ_PROTOCOL=true
FEATURE_KUBERNETES_DEPLOYMENT=false
FEATURE_AUTO_AGENT_SCALING=false

# ============================================================================
# TESTING
# ============================================================================

# Test settings
RUN_TESTS_ON_STARTUP=false
TEST_COVERAGE_THRESHOLD=80
INTEGRATION_TESTS_ENABLED=true

# ============================================================================
# METADATA
# ============================================================================

ENVIRONMENT=development  # development, staging, production
VERSION=1.0.0
CONFIG_VERSION=1.0.0
DEPLOYED_AT=2025-10-10T05:30:00Z

# ============================================================================
# CUSTOM AGENT SETTINGS
# ============================================================================

# Agent-specific configurations can be added below
# Example: AGENT_LIBRARIAN_MAX_DOCS=1000
