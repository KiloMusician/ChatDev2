# Quest & Progress Tracking
QUEST_LOG=${NUSYQ_HUB}\src\Rosetta_Quest_System\quest_log.jsonl
ZETA_TRACKER=${NUSYQ_HUB}\config\ZETA_PROGRESS_TRACKER.json
