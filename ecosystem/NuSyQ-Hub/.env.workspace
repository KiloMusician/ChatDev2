# ============================================================================
# PYTHON ENVIRONMENTS
# ============================================================================

# Python interpreters (auto-detected, fallback provided)
PYTHON_HUB=${NUSYQ_HUB_VENV}\Scripts\python.exe
PYTHON_ROOT=${NUSYQ_ROOT_VENV}\Scripts\python.exe

# ============================================================================
# OPERATING MODES
# ============================================================================

# Default: normal (full access)
# Options: overnight (restricted, safe mode), analysis (diagnostic only)
WORKSPACE_MODE=normal

# Copilot bridge mode for agent router:
# - disabled: explicit failure with handoff guidance
# - mock: local mock response
# - live: attempt API bridge request
NUSYQ_COPILOT_BRIDGE_MODE=intermediary

# ============================================================================
# AUTOMATIC CONTEXT DETECTION
# ============================================================================

# When sourced by PowerShell, this sets:
# - $env:CURRENT_WORKSPACE_FOLDER (auto-detected from pwd)
# - $env:WORKSPACE_CONTEXT (hub/root/verse/anchor)
# - $env:WORKSPACE_PYTHON (correct Python interpreter)
# Rules:
# 1. If pwd starts with NUSYQ_HUB → context=hub, python=PYTHON_HUB
# 2. If pwd starts with NUSYQ_ROOT → context=root, python=PYTHON_ROOT
# 3. If pwd starts with SIMULATEDVERSE → context=verse, python=(node/npm)
# 4. Otherwise → default to NUSYQ_HUB context
NUSYQ_COPILOT_BRIDGE_ENDPOINT=http://127.0.0.1:8000/api/intermediary
NUSYQ_COPILOT_BRIDGE_HEALTH_URL=http://127.0.0.1:8000/api/health
NUSYQ_SIMULATEDVERSE_MODE=always_on
# SimulatedVerse server binds to PORT=5001 (5000 reserved for Wallpaper Engine)
SIMULATEDVERSE_PORT=5001

# ============================================================================
# CULTURE SHIP ALIASES (expected by src/culture_ship/health_probe.py)
# ============================================================================
NUSYQ_HUB_PATH=C:\Users\keath\Desktop\Legacy\NuSyQ-Hub
SIMULATEDVERSE_PATH=C:\Users\keath\Desktop\SimulatedVerse\SimulatedVerse
NUSYQ_ROOT_PATH=C:\Users\keath\NuSyQ

# ============================================================================
# LM STUDIO (network-hosted, not localhost)
# ============================================================================
# Override the default 127.0.0.1:1234 probe in src/dispatch/agent_registry.py
LMSTUDIO_BASE_URL=http://10.0.0.172:1234

# ============================================================================
# AGENT ROUTER TIMEOUTS
# ============================================================================
# Codex CLI: 180s default was too short for large code review tasks (times out).
# Set to 600s (10 min) for comprehensive analysis. Per-dispatch override:
#   nusyq_dispatch.py ask codex "..." --timeout=900
# Or pass context: {"timeout_seconds": 900} in task.context
NUSYQ_CODEX_ROUTER_TIMEOUT_S=600
# Claude CLI: same pattern
NUSYQ_CLAUDE_ROUTER_TIMEOUT_S=600
# Optional multiplier for breathing-factor-aware scaling (1.0 = no scaling).
# Set to >1.0 during heavy load; Culture Ship can adjust this automatically.
NUSYQ_ROUTER_TIMEOUT_MULT=1.0
# LM Studio: default 30s is too short for inference — httpx.ReadTimeout has empty __str__
# causing "LM Studio request failed: " with no detail. Set to 120s (2 min) for typical models.
NUSYQ_LMSTUDIO_TIMEOUT=120

# ============================================================================
# SKYCLAW GATEWAY (Rust agent sidecar, default port :8080)
# ============================================================================
# Override the default probe URL (host 127.0.0.1, port 8080) in agent_registry.py
NUSYQ_SKYCLAW_GATEWAY_URL=http://127.0.0.1:8080
# Set to true to auto-start the gateway when MJOLNIR boots (future: skyclaw_actions.py)
SKYCLAW_GATEWAY_AUTO_START=false
# Notification routing: guild events forwarded to this channel/user via OpenClaw
GUILD_NOTIFY_CHANNEL=internal
GUILD_NOTIFY_USER=guild-feed

# ============================================================================
# OPENCLAW GATEWAY (WebSocket + HTTP REST, ports :18789 + :18790)
# ============================================================================
# WebSocket gateway URL (inbound messages from 12+ messaging platforms)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# HTTP REST API URL (outbound channel sends via channels/send endpoint)
OPENCLAW_API_URL=http://127.0.0.1:18790
# Bridge probe URL (MJOLNIR agent_registry.py probes HTTP dashboard on port 18789)
OPENCLAW_PROBE_URL=http://127.0.0.1:18789/

# ============================================================================
# CHATDEV OLLAMA FALLBACK (no OpenAI key required)
# ============================================================================
# Enable Ollama backend for ChatDev when OpenAI key is not configured.
# qwen2.5-coder:14b is the best available local code model.
CHATDEV_USE_OLLAMA=1
CHATDEV_OLLAMA_MODEL=qwen2.5-coder:14b
CHATDEV_OLLAMA_BASE_URL=http://127.0.0.1:11434

# ============================================================================
# COPILOT AGENT EXTENSIONS
# ============================================================================
# Default Copilot CLI agent extension (override per-dispatch via context["copilot_agent"])
# Leave empty to use default Copilot agent.
# Examples: raptor, gpt-4o, gpt-5.1-codex, etc.
NUSYQ_COPILOT_DEFAULT_AGENT=
# Enable GitHub MCP tools by default for Copilot CLI dispatches
NUSYQ_COPILOT_ENABLE_GITHUB_MCP=false

# ============================================================================
# HERMES-AGENT (OpenRouter autonomous CLI agent)
# ============================================================================
# Hermes-Agent CLI at: state/runtime/external/hermes-agent/cli.py
# API key — set ONE of these (OPENROUTER_API_KEY is the canonical var)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# HERMES_HOME: override ~/.hermes (user config + .env for hermes-specific settings)
# HERMES_HOME=C:\Users\keath\.hermes
# Default model (leave empty to use Hermes default: anthropic/claude-opus-4-20250514)
HERMES_DEFAULT_MODEL=
# Dispatch via MJOLNIR:
#   python scripts/nusyq_dispatch.py ask hermes "Review src/tools/agent_task_router.py"
#   python scripts/nusyq_dispatch.py ask hermes "Analyze codebase" --context='{"toolsets":"web,terminal","worktree":true}'

# ============================================================================
# LOCAL MODEL FALLBACK CONFIG
# ============================================================================
# Controls automatic fallback to local LLMs when a cloud agent is rate-limited.
# Options: "auto" (try ollama then lmstudio), "ollama", "lmstudio", "off"
NUSYQ_CODEX_FALLBACK=auto
NUSYQ_CLAUDE_FALLBACK=auto
NUSYQ_COPILOT_FALLBACK=auto

# How long (hours) to persist the rate-limit bypass after detection
# Codex: 72h (Codex free tier monthly cap); Claude/Copilot: 1h (API 429 is short)
NUSYQ_CODEX_RATE_LIMIT_HOURS=72
NUSYQ_CLAUDE_RATE_LIMIT_HOURS=1
NUSYQ_COPILOT_RATE_LIMIT_HOURS=1

# To manually pre-populate rate-limit state (e.g. when you know Codex is down):
#   python -c "from src.utils.rate_limit_guard import get_rate_limit_guard; get_rate_limit_guard().mark_rate_limited('codex', duration_hours=72)"
# To clear:
#   python -c "from src.utils.rate_limit_guard import get_rate_limit_guard; get_rate_limit_guard().clear_rate_limit('codex')"
