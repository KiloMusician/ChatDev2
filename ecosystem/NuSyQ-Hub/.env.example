# Example environment variables for NuSyQ-Hub
# Copy this to .env and fill in actual paths/keys before running ChatDev-related commands

# Path to ChatDev installation (can be a repo path or installation root)
CHATDEV_PATH=C:/path/to/ChatDev

# Optional: ChatDev runner or entrypoint (if different)
CHATDEV_RUN_CMD=python run.py

# Optional: API key or token if ChatDev instance requires one (leave blank if not applicable)
CHATDEV_API_KEY=

# Optional: Ollama/LLM overrides used by integration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST=localhost
# ========================================
# NuSyQ-Hub Environment Configuration
# ========================================
# This file documents all environment variables used by the NuSyQ-Hub system.
# Copy this file to `.env` and customize values for your environment.
#
# Created: 2025-10-11
# Updated: 2025-10-13 (Added CHATDEV_PATH configuration - CRITICAL for integration)
#

# ========================================
# CHATDEV INTEGRATION (CRITICAL - MUST BE SET)
# ========================================
# Path to ChatDev installation - REQUIRED for multi-agent orchestration
CHATDEV_PATH=C:\Users\keath\NuSyQ\ChatDev

# ========================================
# HTTP TIMEOUT CONFIGURATION
# ========================================
# Global and service-specific HTTP request timeouts (in seconds)

# Global default for all HTTP requests
HTTP_TIMEOUT_SECONDS=10

# Ollama-specific HTTP calls (defaults to HTTP_TIMEOUT_SECONDS if not set)
OLLAMA_HTTP_TIMEOUT_SECONDS=10

# SimulatedVerse HTTP calls (defaults to HTTP_TIMEOUT_SECONDS if not set)
SIMULATEDVERSE_HTTP_TIMEOUT_SECONDS=10

# ========================================
# SUBPROCESS & PROCESS MANAGEMENT
# ========================================
# Timeouts for subprocess execution, tool checks, and process management

# Maximum timeout for Ollama subprocess runs
# Set to empty or omit for NO enforced timeout (recommended for local LLM inference)
# Example: OLLAMA_MAX_TIMEOUT_SECONDS=300 (5 minutes max)
OLLAMA_MAX_TIMEOUT_SECONDS=

# General subprocess timeout for quick checks (git, pip list, etc.)
SUBPROCESS_TIMEOUT_SECONDS=5

# Timeout for checking if CLI tools are installed (ollama --version, python --version, etc.)
TOOL_CHECK_TIMEOUT_SECONDS=10

# Timeout for pip package installation operations
PIP_INSTALL_TIMEOUT_SECONDS=300

# Timeout for automated fix tools (black, ruff, autopep8, etc.)
FIX_TOOL_TIMEOUT_SECONDS=120

# Timeout for analysis tools (pytest, mypy, coverage, etc.)
ANALYSIS_TOOL_TIMEOUT_SECONDS=180

# Timeout for auto-heal subprocess attempts
HEAL_TIMEOUT_SECONDS=30

# Timeout when joining monitoring threads
THREAD_JOIN_TIMEOUT_SECONDS=5

# Timeout for queue.get() operations in threaded components
QUEUE_GET_TIMEOUT_SECONDS=1.0

# Timeout for graceful shutdown of monitoring loops and background processes
GRACEFUL_SHUTDOWN_TIMEOUT_SECONDS=15.0

# ========================================
# AGENT & SERVICE TIMEOUTS
# ========================================
# Timeouts for AI agent coordination and service interactions

# Timeout for SimulatedVerse agent result checks
SIMULATEDVERSE_RESULT_TIMEOUT_SECONDS=30

# Timeout for ChatDev status checks
CHATDEV_STATUS_TIMEOUT_SECONDS=10

# Timeout for Council voting operations
COUNCIL_VOTE_TIMEOUT_SECONDS=30

# Timeout for PowerShell syntax validation
POWERSHELL_SYNTAX_TIMEOUT_SECONDS=30

# ========================================
# ADAPTIVE TIMEOUT BEHAVIOR
# ========================================
# Enable per-model adaptive timeout estimation using Exponential Moving Average (EMA)

# Enable adaptive timeout learning (true/false)
# When enabled, the system records execution duration per model and computes EMA
# History is persisted to .cache/ollama_timeouts.json
OLLAMA_ADAPTIVE_TIMEOUT=false

# ========================================
# API KEYS & SECRETS
# ========================================
# External service API keys

# VS Code extensions (AIQuickFix and Code Smell GPT)
AIQUICKFIX_API_KEY=your-aiquickfix-api-key
CODE_SMELL_GPT_API_KEY=your-code-smell-gpt-api-key

# OpenAI API Key (if using OpenAI models)
OPENAI_API_KEY=your-openai-api-key

# Ollama API Key (typically not required for local instance)
OLLAMA_API_KEY=your-ollama-api-key

# Anthropic API Key (if using Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Hugging Face Token (if using Hugging Face models)
# HUGGINGFACE_TOKEN=hf_...

# ========================================
# CHATDEV INTEGRATION
# ========================================
# ChatDev multi-agent development environment configuration

# Path to ChatDev installation (Windows example: C:\Users\<user>\NuSyQ\ChatDev\)
# Required for ChatDev integration features
CHATDEV_PATH=/path/to/ChatDev

# ========================================
# SIMULATEDVERSE CONFIGURATION
# ========================================
# Configuration for SimulatedVerse consciousness simulation engine

# SimulatedVerse Express server port
SIMULATEDVERSE_PORT=5000

# SimulatedVerse React UI port
SIMULATEDVERSE_REACT_PORT=3000

# ========================================
# OLLAMA CONFIGURATION
# ========================================
# Local Ollama LLM runtime configuration

# Ollama API base URL
OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model for general tasks
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:14b

# ========================================
# DOCKER CREDENTIALS (REQUIRED for docker compose up)
# ========================================
# These MUST be set — no defaults are provided so compose fails fast if missing.
# Copy this file to .env and set strong passwords before running docker compose.

# PostgreSQL password (any profile that includes the 'full' or 'monitoring' services)
POSTGRES_PASSWORD=change-me-strong-password

# Redis password (any profile including redis)
REDIS_PASSWORD=change-me-strong-password

# Grafana admin password (monitoring profile)
GRAFANA_PASSWORD=change-me-strong-password

# ========================================
# DATABASE & STORAGE
# ========================================
# Database connection and storage configuration

# Database URL (SQLite default)
DATABASE_URL=sqlite:///nu.db

# Secret key for session management
SECRET_KEY=change-me

# ========================================
# LOGGING & DEBUGGING
# ========================================
# Logging levels and debug options

# Python logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable verbose console output (true/false)
VERBOSE=false

# Enable debug mode (true/false)
DEBUG=false

# ========================================
# DEVELOPMENT OPTIONS
# ========================================
# Development and testing configuration

# Enable experimental features (true/false)
EXPERIMENTAL_FEATURES=false

# Skip certain validations during development (true/false)
DEV_MODE=false

# ========================================
# NOTES
# ========================================
# - All timeout values are in seconds unless otherwise specified
# - Empty values or omitted variables will use sensible defaults
# - For offline-first development with Ollama, leave OLLAMA_MAX_TIMEOUT_SECONDS empty
# - Adaptive timeout requires OLLAMA_ADAPTIVE_TIMEOUT=true and creates .cache/ollama_timeouts.json
# - See docs/TIMEOUT_POLICY.md for comprehensive timeout configuration guide
# - See .github/copilot-instructions.md for multi-repository architecture details
# - 38 Python files updated with environment-driven timeout configuration (100% coverage)
# - 14 timeout-related environment variables introduced across 9 systematic batches


# ========================================
# CROSS-REPOSITORY INTEGRATION (CRITICAL)
# ========================================

# ChatDev Integration Path
CHATDEV_PATH=C:\Users\keath\NuSyQ\ChatDev
CHATDEV_API_KEY=ollama-local-model

# NuSyQ Root Path
NUSYQ_ROOT_PATH=C:\Users\keath\NuSyQ

# SimulatedVerse Integration
SIMULATEDVERSE_PATH=C:\Users\keath\Desktop\SimulatedVerse\SimulatedVerse

# ========================================
# AI MODEL CONFIGURATION (STANDARDIZED)
# ========================================

# Ollama Configuration (STANDARDIZED PORT: 11434)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b

# GitHub Copilot Extension
GITHUB_COPILOT_API_KEY=your-api-token-here

# Modular Agent-Model System
USE_MODULAR_MODELS=true
MODEL_ROUTING_ENABLED=true

# ========================================
# MCP SERVER CONFIGURATION
# ========================================

MCP_SERVER_URL=http://localhost:8000
MCP_SERVER_ENABLED=true

# ========================================
# TEMPLE OF KNOWLEDGE INTEGRATION
# ========================================

TEMPLE_API_URL=http://localhost:5000
TEMPLE_ENABLED=false
CONSCIOUSNESS_TRACKING=true

# ========================================
# KNOWLEDGE BASE & PERSISTENCE
# ========================================

KNOWLEDGE_BASE_PATH=C:\Users\keath\NuSyQ\knowledge-base.yaml
STATE_DIR=C:\Users\keath\NuSyQ\State
