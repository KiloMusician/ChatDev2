# NuSyQ-Hub Docker Environment Variables

# === Application Configuration ===
ENVIRONMENT=production
APP_PORT=5000
DEV_APP_PORT=5001
DEBUG_PORT=5678

# === Container Registry ===
REGISTRY=ghcr.io
IMAGE_NAME=nusyq-hub
TAG=latest

# === Ollama Configuration ===
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
MOCK_OLLAMA_PORT=8080

# === ChatDev Configuration ===
CHATDEV_PATH=/app/external/chatdev

# === Database Configuration ===
POSTGRES_PORT=5432
POSTGRES_USER=nusyq
POSTGRES_PASSWORD=nusyq_password
POSTGRES_DB=nusyq

# === Redis Configuration ===
REDIS_PORT=6379

# === Nginx Configuration ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === Monitoring Configuration ===
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=admin

# === Security (Add your actual values) ===
# GITHUB_TOKEN=your_token_here
# API_KEY=your_api_key_here
