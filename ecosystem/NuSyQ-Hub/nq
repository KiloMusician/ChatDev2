def cmd_watch(args):
    """Watch for file changes and auto-rebuild search index."""
    import time
    from datetime import datetime

    print("👁️  NuSyQ File Watcher - Auto Index Rebuild")
    print("=" * 50)

    root = Path(__file__).parent
    index_dir = root / "state" / "search_index"

    # Extensions to watch
    watch_extensions = {".py", ".md", ".json", ".yaml", ".yml", ".toml", ".txt"}

    # Directories to ignore
    ignore_dirs = {
        "__pycache__", ".git", ".venv", "venv", "node_modules",
        ".mypy_cache", ".pytest_cache", ".ruff_cache", "htmlcov"
    }

    def get_file_hash(file_path):
        """Get hash of file modification time and size."""
        try:
            stat = file_path.stat()
            return f"{stat.st_mtime}:{stat.st_size}"
        except (OSError, IOError):
            return None

    def scan_files():
        """Scan all files and return hash of their states."""
        file_states = {}
        for ext in watch_extensions:
            for file_path in root.rglob(f"*{ext}"):
                # Skip ignored directories
                if any(ignored in file_path.parts for ignored in ignore_dirs):
                    continue
                file_hash = get_file_hash(file_path)
                if file_hash:
                    file_states[str(file_path)] = file_hash
        return file_states

    def rebuild_index():
        """Rebuild the search index."""
        print(f"\n🔄 Rebuilding search index at {datetime.now().strftime('%H:%M:%S')}...")
        try:
            from src.search.index_builder import IndexBuilder
            builder = IndexBuilder(root)
            builder.build_all()
            print("✅ Index rebuilt successfully")
            return True
        except ImportError:
            print("❌ Could not import IndexBuilder")
            return False
        except Exception as e:
            print(f"❌ Index rebuild failed: {e}")
            return False

    # Parse arguments
    interval = 5  # Default 5 seconds
    for i, arg in enumerate(args):
        if arg in ("-i", "--interval") and i + 1 < len(args):
            try:
                interval = int(args[i + 1])
            except ValueError:
                print(f"Invalid interval: {args[i + 1]}, using default {interval}s")

    print(f"📂 Watching: {root}")
    print(f"⏱️  Check interval: {interval}s")
    print(f"📁 Extensions: {', '.join(sorted(watch_extensions))}")
    print("\nPress Ctrl+C to stop watching.\n")

    # Initial scan
    previous_states = scan_files()
    print(f"📊 Initial scan: {len(previous_states)} files indexed")

    # Build initial index if it doesn't exist
    if not (index_dir / "file_metadata.json").exists():
        print("📝 No index found, building initial index...")
        rebuild_index()

    try:
        while True:
            time.sleep(interval)
            current_states = scan_files()

            # Check for changes
            changed = []
            added = []
            removed = []

            for path, hash_val in current_states.items():
                if path not in previous_states:
                    added.append(path)
                elif previous_states[path] != hash_val:
                    changed.append(path)

            for path in previous_states:
                if path not in current_states:
                    removed.append(path)

            # Report and rebuild if changes detected
            if changed or added or removed:
                print(f"\n🔔 Changes detected at {datetime.now().strftime('%H:%M:%S')}:")
                for path in added[:5]:
                    print(f"   + {Path(path).relative_to(root)}")
                for path in changed[:5]:
                    print(f"   ~ {Path(path).relative_to(root)}")
                for path in removed[:5]:
                    print(f"   - {Path(path).relative_to(root)}")

                total_changes = len(added) + len(changed) + len(removed)
                if total_changes > 5:
                    print(f"   ... and {total_changes - 5} more changes")

                rebuild_index()
                previous_states = current_states

    except KeyboardInterrupt:
        print("\n\n👋 Watch stopped.")
        return 0


