def _cmd_factory_generate(args):
    """Generate a project using AsyncProjectFactory."""
    import asyncio

    # Parse arguments
    name = None
    template = None
    language = None
    provider = None
    description = ""
    parallel = True
    json_output = False

    positional = []
    for arg in args:
        if arg.startswith("--template="):
            template = arg.split("=", 1)[1]
        elif arg.startswith("--lang="):
            language = arg.split("=", 1)[1]
        elif arg.startswith("--language="):
            language = arg.split("=", 1)[1]
        elif arg.startswith("--provider="):
            provider = arg.split("=", 1)[1]
        elif arg.startswith("--desc="):
            description = arg.split("=", 1)[1]
        elif arg == "--sequential":
            parallel = False
        elif arg == "--json":
            json_output = True
        elif not arg.startswith("--"):
            positional.append(arg)

    if not positional:
        print("Usage: nq factory generate <name> [options]")
        print("  --template=<name>   Template to use (e.g., rust_cli, godot_2d_game)")
        print("  --lang=<language>   Language (python, rust, typescript, etc.)")
        print("  --provider=<name>   Provider (ollama, claude, openai)")
        print("  --desc=<text>       Project description")
        print("  --sequential        Disable parallel generation")
        print("  --json              Output result as JSON")
        print()
        print("Examples:")
        print("  nq factory generate MyGame --template=godot_2d_game")
        print("  nq factory generate MyCLI --lang=rust --provider=ollama")
        print("  nq factory generate MyAPI --template=fastapi_service")
        return 1

    name = positional[0]

    try:
        from src.factories.async_factory import AsyncProjectFactory

        factory = AsyncProjectFactory()

        print(f"Generating project: {name}")
        if template:
            print(f"  Template: {template}")
        if language:
            print(f"  Language: {language}")
        if provider:
            print(f"  Provider: {provider}")
        print()

        async def run_generation():
            return await factory.generate(
                name=name,
                template=template,
                language=language,
                provider=provider,
                description=description,
                parallel=parallel,
            )

        result = asyncio.run(run_generation())

        if json_output:
            import json
            print(json.dumps(result.to_dict(), indent=2))
        else:
            print("=" * 50)
            print(f"Project: {result.name}")
            print("=" * 50)
            print(f"  Output:     {result.output_path}")
            print(f"  Type:       {result.type}")
            print(f"  Language:   {result.language}")
            print(f"  Provider:   {result.provider}")
            print(f"  Model:      {result.model}")
            print()
            print(f"  Files:      {result.successful_files}/{result.total_files} successful")
            if result.placeholder_files:
                print(f"  Placeholders: {result.placeholder_files}")
            if result.failed_files:
                print(f"  Failed:     {result.failed_files}")
            print(f"  Success:    {result.success_rate:.1f}%")
            print()
            print(f"  Tokens:     {result.total_tokens}")
            print(f"  Time:       {result.total_time_ms}ms")
            print(f"  Est. cost:  ${result.estimated_cost_usd:.4f}")

            if result.errors:
                print()
                print("  Errors:")
                for err in result.errors[:5]:
                    print(f"    - {err.get('file')}: {err.get('error')}")

            print()
            if result.success:
                print(f"✅ Generated successfully at {result.output_path}")
            else:
                print(f"⚠️  Generation completed with issues")

        return 0 if result.success else 1

    except FileNotFoundError as e:
        print(f"❌ Template not found: {e}")
        return 1
    except ValueError as e:
        print(f"❌ Configuration error: {e}")
        return 1
    except Exception as e:
        print(f"❌ Generation failed: {e}")
        import traceback
        traceback.print_exc()
        return 1


def cmd_factory(args):
    """Factory operations."""
    if not args:
        print("Usage: nq factory <list|generate|health|doctor|autopilot|ci-gate|inspect-examples> [options]")
        print("  nq factory list [templates|languages|providers]")
        print("  nq factory generate <name> [--template=<t>] [--lang=<l>] [--provider=<p>]")
        print("  nq factory health [--no-packaging] [--json]")
        print("  nq factory doctor [--strict-hooks] [--no-examples] [--fix] [--json]")
        print("  nq factory autopilot [--strict-hooks] [--no-examples] [--fix] [--ci-gate] [--json] [path ...]")
        print("  nq factory ci-gate [--fix] [--json] [path ...]")
        print("  nq factory inspect-examples [path ...] [--json]")
        return 1
    subcmd = args[0]
    json_output = "--json" in args[1:]

    # Handle 'generate' subcommand with async factory
    if subcmd == "generate":
        return _cmd_factory_generate(args[1:])

    # Handle 'list' subcommand
    if subcmd == "list":
        return _cmd_factory_list(args[1:])

    try:
        from src.factories import ProjectFactory
    except Exception as e:
        print(f"❌ Factory module unavailable: {e}")
        return 1

    factory = ProjectFactory()

    if subcmd == "health":
        include_packaging = "--no-packaging" not in args[1:]
        report = factory.run_health_check(include_packaging=include_packaging)

        if json_output:
            print(json.dumps(report, indent=2))
            return 0 if report.get("healthy") else 1

        print("🏭 Factory Health")
        print("=" * 40)
        print("Running smoke probes:")
        print(" - Provider fallback (ChatDev -> Ollama)")
        print(" - Runtime bootstrap wiring")
        if include_packaging:
            print(" - Runtime profile packaging adapters")

        for check in report.get("checks", []):
            status = "✅" if check.get("passed") else "❌"
            print(f"\n{status} {check.get('name')}")
            details = check.get("details", {})
            if isinstance(details, dict):
                for key, value in details.items():
                    print(f"   {key}: {value}")

        print("\n" + "=" * 40)
        overall = "healthy" if report.get("healthy") else "degraded"
        print(f"Factory health: {overall}")
        return 0 if report.get("healthy") else 1

    if subcmd == "inspect-examples":
        raw_paths = [arg for arg in args[1:] if not arg.startswith("--")]
        report = factory.inspect_reference_games(paths=raw_paths or None)

        if json_output:
            print(json.dumps(report, indent=2))
            return 0

        print("🧪 Factory Example Inspection")
        print("=" * 40)
        print("Profiles:")
        for profile, count in report.get("profiles", {}).items():
            print(f" - {profile}: {count}")

        print("\nReference Reports:")
        for item in report.get("reports", []):
            status = "✅" if item.get("exists") else "⚠️"
            print(f"\n{status} {item.get('path')}")
            print(f"   runtime_profile: {item.get('runtime_profile')}")
            signals = item.get("signals", [])
            print(f"   signals: {', '.join(signals) if signals else 'none'}")
            recs = item.get("recommendations", [])
            if recs:
                print(f"   recommendation: {recs[0]}")

        print("\nRecommendations:")
        for rec in report.get("recommendations", []):
            print(f" - {rec}")
        return 0

    if subcmd == "doctor":
        strict_hooks = "--strict-hooks" in args[1:]
        include_examples = "--no-examples" not in args[1:]
        apply_fix = "--fix" in args[1:]
        if apply_fix:
            report = factory.run_doctor_fix(
                strict_hooks=strict_hooks,
                include_examples=include_examples,
                include_health=True,
            )
            healthy = bool(report.get("post_fix", {}).get("healthy"))
        else:
            report = factory.run_doctor(
                strict_hooks=strict_hooks,
                include_examples=include_examples,
                include_health=True,
            )
            healthy = bool(report.get("healthy"))

        if json_output:
            print(json.dumps(report, indent=2))
            return 0 if healthy else 1

        print("🩺 Factory Doctor")
        print("=" * 40)
        if apply_fix:
            print(f"status: {report.get('status')}")
            print(f"healthy: {healthy}")
            actions = report.get("actions", [])
            print("\nApplied Actions:")
            for action in actions:
                print(f" - {action.get('action')}: applied={action.get('applied')}")
            post = report.get("post_fix", {})
            issues = post.get("issues", [])
            print("\nPost-fix Issues:")
            if issues:
                for issue in issues:
                    print(f" - [{issue.get('code')}] {issue.get('message')}")
            else:
                print(" - none")
            print("\nRecommendations:")
            for rec in post.get("recommendations", []):
                print(f" - {rec}")
            return 0 if healthy else 1

        print(f"status: {report.get('status')}")
        print(f"healthy: {healthy}")

        quality = report.get("generation_quality", {})
        print("\nGeneration quality:")
        print(f" - sample_size: {quality.get('sample_size')}")
        print(f" - fallback_runs: {quality.get('fallback_runs')}")
        print(f" - placeholder_runs: {quality.get('placeholder_runs')}")
        print(f" - max_placeholder_ratio: {quality.get('max_placeholder_ratio')}")

        issues = report.get("issues", [])
        print("\nIssues:")
        if issues:
            for issue in issues:
                print(f" - [{issue.get('code')}] {issue.get('message')}")
        else:
            print(" - none")

        print("\nRecommendations:")
        for rec in report.get("recommendations", []):
            print(f" - {rec}")

        return 0 if healthy else 1

    if subcmd in ("autopilot", "ci-gate"):
        ci_gate = subcmd == "ci-gate" or "--ci-gate" in args[1:]
        strict_hooks = "--strict-hooks" in args[1:] or ci_gate
        include_examples = ("--no-examples" not in args[1:]) and not ci_gate
        apply_fix = "--fix" in args[1:]
        raw_paths = [arg for arg in args[1:] if not arg.startswith("--")]
        report = factory.run_autopilot(
            fix=apply_fix,
            strict_hooks=strict_hooks,
            include_examples=include_examples,
            include_workspace=ci_gate,
            recent_limit=25,
            example_paths=raw_paths or None,
        )
        if json_output:
            print(json.dumps(report, indent=2))
            return 0 if report.get("healthy") else 1

        print("🛰️ Factory Autopilot")
        print("=" * 40)
        print(f"status: {report.get('status')}")
        print(f"healthy: {report.get('healthy')}")
        if ci_gate:
            print("mode: ci-gate")

        print("\nPatch Plan:")
        for item in report.get("patch_plan", []):
            print(
                f" - [{item.get('priority')}] {item.get('action')} "
                f"(auto_fix={item.get('auto_fix')})"
            )
        if apply_fix:
            fix_report = report.get("fix_applied", {}) or {}
            print("\nFix Actions:")
            for action in fix_report.get("actions", []):
                print(f" - {action.get('action')}: applied={action.get('applied')}")

        return 0 if report.get("healthy") else 1

    print(f"Unknown factory subcommand: {subcmd}")
    return 1


def main():
    """Main entry point."""
    if len(sys.argv) < 2:
        print(__doc__)
        return 0

    cmd = sys.argv[1]
    args = sys.argv[2:]

    commands = {
        "search": cmd_search,
        "quest": cmd_quest,
        "council": cmd_council,
        "bg": cmd_bg,
        "background": cmd_bg,
        "status": cmd_status,
        "boot": cmd_boot,
        "watch": cmd_watch,
        "cycle": cmd_cycle,
        "analyze": cmd_analyze,
        "fix": cmd_fix,
        "health": cmd_health,
        "connector": cmd_connector,
        "workflow": cmd_workflow,
        "test-loop": cmd_test_loop,
        "outputs": cmd_outputs,
        "zero": cmd_zero,
        "protocol": cmd_protocol,
        "factory": cmd_factory,
        "lang": cmd_lang,
        "language": cmd_lang,
        "gen": cmd_gen,
        "generator": cmd_gen,
    }

    if cmd in commands:
        return commands[cmd](args)
    elif cmd in ("-h", "--help", "help"):
        print(__doc__)
        return 0
    else:
        print(f"Unknown command: {cmd}")
        print(__doc__)
        return 1


if __name__ == "__main__":
    sys.exit(main())
