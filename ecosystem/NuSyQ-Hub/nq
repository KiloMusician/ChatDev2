                    f" - PID {item.get('pid')}: age={item.get('age_minutes')}m, "
                    f"cpu={item.get('cpu_seconds')}"
                )
        return 0

    if subcmd == "hints":
        channel = None
        since_minutes = 60
        sample_lines = 2000
        sns_mode = False
        i = 1
        while i < len(args):
            arg = args[i]
            if arg == "--json":
                i += 1
                continue
            if arg == "--sns":
                sns_mode = True
                i += 1
                continue
            if arg == "--since" and i + 1 < len(args):
                i += 1
                try:
                    since_minutes = max(1, int(args[i]))
                except ValueError:
                    print(f"Invalid --since value: {args[i]}")
                    return 1
                i += 1
                continue
            if arg == "--sample-lines" and i + 1 < len(args):
                i += 1
                try:
                    sample_lines = max(100, int(args[i]))
                except ValueError:
                    print(f"Invalid --sample-lines value: {args[i]}")
                    return 1
                i += 1
                continue
            if channel is None and not arg.startswith("--"):
                channel = arg
                i += 1
                continue
            print(f"Unknown option for hints: {arg}")
            return 1

        result = inventory.hints_report(
            channel=channel,
            since_minutes=since_minutes,
            sample_lines=sample_lines,
        )
        if json_mode:
            print(json.dumps(result, indent=2))
            return 0

        summary = result.get("summary", {})
        print("🧠 Output Hints")
        print("=" * 50)
        print(f"Channel filter: {result.get('channel_filter') or 'all'}")
        print(f"Since: {result.get('since_minutes')} minutes")
        print(f"Analyzed lines: {result.get('analyzed_lines')}")
        print(
            "Issues: "
            f"{summary.get('issue_count', 0)} "
            f"(high={summary.get('high', 0)}, medium={summary.get('medium', 0)}, low={summary.get('low', 0)})"
        )

        issues = result.get("issues", [])
        if not issues:
            print("\nNo high-signal recurring issues detected in the selected window.")
            return 0

        for issue in issues:
            print(f"\n[{issue.get('severity', 'unknown').upper()}] {issue.get('title')}")
            print(f"  Evidence: {issue.get('evidence_count')} hits")
