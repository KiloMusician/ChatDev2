def cmd_fix(args):
    """Run auto-fixes on a file or directory."""
    if not args:
        print("Usage: nq fix <path> [--dry-run]")
        return 1

    target_path = args[0]
    dry_run = "--dry-run" in args or "-n" in args

    print(f"🔧 Auto-fixing: {target_path}")
    if dry_run:
        print("   (dry run - no changes will be made)")
    print("=" * 50)

    root = Path(__file__).parent
    full_path = Path(target_path)
    if not full_path.is_absolute():
        full_path = root / target_path

    if not full_path.exists():
        print(f"❌ Path not found: {full_path}")
        return 1

    fixes_applied = 0

    try:
        import subprocess
        import sys

        # Run ruff check with --fix
        print("\n📋 Running ruff auto-fix...")
        ruff_args = [sys.executable, "-m", "ruff", "check", str(full_path), "--fix"]
        if dry_run:
            ruff_args = [sys.executable, "-m", "ruff", "check", str(full_path)]

        result = subprocess.run(ruff_args, capture_output=True, text=True)
        if result.returncode == 0:
            print("   ✅ ruff: No issues or all fixed")
        else:
            issues = result.stdout.count('\n')
            print(f"   ⚠️  ruff: {issues} issues found")
            if not dry_run:
                fixes_applied += 1

        # Run black formatter
        print("\n🎨 Running black formatter...")
        black_args = [sys.executable, "-m", "black", str(full_path)]
        if dry_run:
            black_args.append("--check")

        result = subprocess.run(black_args, capture_output=True, text=True)
        if "reformatted" in result.stderr or result.returncode == 0:
            if "reformatted" in result.stderr:
                print("   ✅ black: Files reformatted")
                fixes_applied += 1
            else:
                print("   ✅ black: Already formatted")
        else:
            print(f"   ⚠️  black: {result.stderr[:100]}")

        # Run isort
        print("\n📦 Running isort...")
        isort_args = [sys.executable, "-m", "isort", str(full_path)]
        if dry_run:
            isort_args.append("--check-only")

        result = subprocess.run(isort_args, capture_output=True, text=True)
        if result.returncode == 0:
            print("   ✅ isort: Imports sorted")
            if not dry_run:
                fixes_applied += 1
        else:
            print("   ⚠️  isort: Changes needed")

        print(f"\n{'=' * 50}")
        if dry_run:
            print("🔍 Dry run complete - no changes made")
        else:
            print(f"✅ Fix complete - {fixes_applied} tools applied changes")

        return 0

    except Exception as e:
        print(f"❌ Fix failed: {e}")
        return 1


