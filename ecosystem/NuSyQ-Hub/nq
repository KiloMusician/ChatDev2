def cmd_analyze(args):
    """Quick analyze a file or directory."""
    if not args:
        print("Usage: nq analyze <path> [--type <analysis_type>]")
        print("\nAnalysis types:")
        print("  code_analysis  - General code review (default)")
        print("  security       - Security audit")
        print("  performance    - Performance analysis")
        print("  complexity     - Complexity assessment")
        return 1

    target_path = args[0]
    analysis_type = "code_analysis"

    # Parse arguments
    for i, arg in enumerate(args):
        if arg in ("-t", "--type") and i + 1 < len(args):
            analysis_type = args[i + 1]

    print(f"🔍 Analyzing: {target_path}")
    print(f"📊 Type: {analysis_type}")
    print("=" * 50)

    # Resolve the path
    root = Path(__file__).parent
    full_path = Path(target_path)
    if not full_path.is_absolute():
        full_path = root / target_path

    if not full_path.exists():
        print(f"❌ Path not found: {full_path}")
        return 1

    # Use the nusyq orchestrator for analysis
    result = nusyq.analyze(str(full_path), analysis_type=analysis_type)
    print_result(result)

    # If it's a file, also show quick stats
    if full_path.is_file() and full_path.suffix == ".py":
        print("\n📈 Quick Stats:")
        try:
            content = full_path.read_text(encoding="utf-8")
            lines = content.split("\n")
            code_lines = [line for line in lines if line.strip() and not line.strip().startswith("#")]

            import ast
            try:
                tree = ast.parse(content)
                classes = [n.name for n in ast.walk(tree) if isinstance(n, ast.ClassDef)]
                functions = [n.name for n in ast.walk(tree) if isinstance(n, ast.FunctionDef)]
                imports = sum(1 for n in ast.walk(tree) if isinstance(n, (ast.Import, ast.ImportFrom)))

                print(f"   Lines: {len(lines)} total, {len(code_lines)} code")
                print(f"   Classes: {len(classes)}")
                print(f"   Functions: {len(functions)}")
                print(f"   Imports: {imports}")

                if classes:
                    print(f"   Class names: {', '.join(classes[:5])}")
                if functions:
                    print(f"   Top functions: {', '.join(functions[:5])}")
                    if len(functions) > 5:
                        print(f"   ... and {len(functions) - 5} more")
            except SyntaxError:
                print("   (Could not parse Python AST)")
        except Exception as e:
            print(f"   (Could not read file: {e})")

    elif full_path.is_dir():
        print("\n📁 Directory Contents:")
        try:
            py_files = list(full_path.rglob("*.py"))
            other_files = [f for f in full_path.rglob("*") if f.is_file() and f.suffix != ".py"]
            subdirs = [d for d in full_path.iterdir() if d.is_dir() and not d.name.startswith(".")]

            print(f"   Python files: {len(py_files)}")
            print(f"   Other files: {len(other_files)}")
            print(f"   Subdirectories: {len(subdirs)}")

            if subdirs:
                print(f"   Subdirs: {', '.join(d.name for d in subdirs[:5])}")
        except Exception as e:
            print(f"   (Could not scan directory: {e})")

