            if channels:
                print(f"  Channels: {channels}")
            for tip in issue.get("guidance", [])[:3]:
                print(f"  Guidance: {tip}")
            for step in issue.get("next_steps", [])[:3]:
                print(f"  Next: {step}")
            examples = issue.get("examples", [])
            if examples:
                print(f"  Example: {examples[0]}")

        global_guidance = result.get("global_guidance", [])
        if global_guidance:
            print("\nGlobal guidance:")
            for tip in global_guidance:
                print(f" - {tip}")

        if sns_mode and issues:
            try:
                from src.utils.sns_core_helper import convert_to_sns
            except ImportError:
                print("\nSNS compact mode unavailable (converter import failed).")
                return 0

            print("\nSNS compact hints:")
            for issue in issues[:8]:
                base_text = f"{issue.get('title')}. {' '.join(issue.get('next_steps', [])[:2])}"
                sns_line, meta = convert_to_sns(base_text, aggressive=True)
                print(
                    f" - {issue.get('id')}: {sns_line} "
                    f"(saved {meta.get('savings_pct', 0)}%)"
                )
        return 0

    print(f"Unknown outputs subcommand: {subcmd}")
    print("Usage: nq outputs <scan|tail|diff|stale|hints> [options]")
    return 1


