                        print(f"    Best for: {info['best_for']}")
            return 0
        except Exception as e:
            print(f"Error listing providers: {e}")
            return 1

    else:
        print(f"Unknown lang subcommand: {subcmd}")
        print("Usage: nq lang <list|info|templates|providers>")
        return 1


