def _discover_simverse_path() -> Path | None:
    """Best-effort SimulatedVerse path discovery without heavy filesystem scans."""
    env_path = os.environ.get("NUSYQ_SIMVERSE_PATH", "").strip()
    if env_path:
        candidate = Path(env_path).expanduser()
        if candidate.exists():
            return candidate

    repo_root = Path.cwd()
    candidates = [
        repo_root.parent / "SimulatedVerse",
        repo_root.parent.parent / "SimulatedVerse",
        Path.home() / "Desktop" / "SimulatedVerse",
        Path.home() / "Desktop" / "SimulatedVerse" / "SimulatedVerse",
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


