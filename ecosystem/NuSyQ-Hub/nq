            print(f"❌ Channel not found: {channel}")
            suggestions = result.get("suggestions", [])
            if suggestions:
                print("Did you mean:")
                for suggestion in suggestions[:5]:
                    print(f" - {suggestion}")
            return 1

        print(f"📜 Output tail: {result.get('channel')}")
        print("=" * 50)
        matches = result.get("matches", [])
        if matches:
            print("Sources:")
            for path in matches[:5]:
                print(f" - {path}")
            print()
        for line in result.get("lines", []):
            print(line)
        return 0

    if subcmd == "diff":
        raw_paths = [token for token in args[1:] if not token.startswith("--")]
        old_report = None
        new_report = None

        try:
            if len(raw_paths) >= 1:
                old_report = inventory.load_report(raw_paths[0])
            else:
                default_baselines = [
                    Path("output_source_inventory.json"),
                    Path("state/reports/output_source_inventory.json"),
                ]
                for candidate in default_baselines:
                    if candidate.exists():
                        old_report = inventory.load_report(candidate)
                        break

            if len(raw_paths) >= 2:
                new_report = inventory.load_report(raw_paths[1])
            else:
                new_report = inventory.scan()
                new_report["_loaded_from"] = "fresh_scan"
        except (OSError, json.JSONDecodeError) as e:
            print(f"❌ Failed to load diff reports: {e}")
            return 1

        if old_report is None:
            print("❌ No baseline scan found. Run: nq outputs scan output_source_inventory.json")
            return 1

        result = inventory.diff_reports(old_report, new_report)
        if json_mode:
            print(json.dumps(result, indent=2))
            return 0

        summary = result.get("summary", {})
        print("🧮 Output Source Diff")
        print("=" * 50)
        print(f"Old: {result.get('old_source')}")
        print(f"New: {result.get('new_source')}")
        print(f"Old timestamp: {result.get('old_timestamp')}")
        print(f"New timestamp: {result.get('new_timestamp')}")
        print(f"Added channels: {summary.get('added_channels', 0)}")
        print(f"Removed channels: {summary.get('removed_channels', 0)}")
        print(f"Changed channels: {summary.get('changed_channels', 0)}")
        print(f"Expected missing resolved: {summary.get('missing_resolved', 0)}")
        print(f"Expected missing new: {summary.get('missing_new', 0)}")

        added = result.get("added_channels", [])
        if added:
            print("\nAdded (sample):")
            for name in added[:10]:
                print(f" - {name}")

        removed = result.get("removed_channels", [])
        if removed:
            print("\nRemoved (sample):")
            for name in removed[:10]:
                print(f" - {name}")

        changed = result.get("changed_channels", [])
        if changed:
            print("\nChanged (sample):")
            for item in changed[:10]:
                print(
                    f" - {item.get('channel')}: Δbytes={item.get('delta_bytes')} | "
                    f"{item.get('old_latest_modified')} -> {item.get('new_latest_modified')}"
                )
        return 0

    if subcmd == "stale":
        stale_minutes = 240
        idle_minutes = 30
        sample_lines = 400
        include_static = False
        i = 1
        while i < len(args):
            arg = args[i]
            if arg == "--json":
                i += 1
                continue
            if arg == "--include-static":
                include_static = True
                i += 1
                continue
            if arg == "--minutes" and i + 1 < len(args):
                i += 1
                try:
                    stale_minutes = max(1, int(args[i]))
                except ValueError:
                    print(f"Invalid --minutes value: {args[i]}")
                    return 1
                i += 1
                continue
            if arg == "--idle-minutes" and i + 1 < len(args):
                i += 1
                try:
                    idle_minutes = max(1, int(args[i]))
                except ValueError:
                    print(f"Invalid --idle-minutes value: {args[i]}")
                    return 1
                i += 1
                continue
            if arg == "--sample-lines" and i + 1 < len(args):
                i += 1
                try:
                    sample_lines = max(50, int(args[i]))
                except ValueError:
                    print(f"Invalid --sample-lines value: {args[i]}")
                    return 1
                i += 1
                continue
            print(f"Unknown option for stale: {arg}")
            return 1

        result = inventory.stale_report(
            stale_minutes=stale_minutes,
            idle_shell_minutes=idle_minutes,
            noise_sample_lines=sample_lines,
            include_static_channels=include_static,
        )
        if json_mode:
            print(json.dumps(result, indent=2))
            return 0

        summary = result.get("summary", {})
        print("🧹 Output Source Stale Report")
        print("=" * 50)
        print(f"Stale channels: {summary.get('stale_channels', 0)}")
        print(f"Noisy channels: {summary.get('noisy_channels', 0)}")
        print(f"Idle shells: {summary.get('idle_shells', 0)}")

        stale_channels = result.get("stale_channels", [])
        if stale_channels:
            print("\nStale channels (sample):")
            for item in stale_channels[:10]:
                print(
                    f" - {item.get('channel')}: age={item.get('age_minutes')}m "
                    f"[{', '.join(item.get('source_types', []))}]"
                )

        noisy_channels = result.get("noisy_channels", [])
        if noisy_channels:
            print("\nNoisy channels (sample):")
            for item in noisy_channels[:10]:
                print(
                    f" - {item.get('channel')}: errors={item.get('error_lines')}, "
                    f"warnings={item.get('warning_lines')}, repeat={item.get('top_repeat_count')}"
