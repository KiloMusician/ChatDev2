def cmd_bg(args):
    """Background task operations."""
    if not args:
        print("Usage: nq bg <dispatch|status|list|process|run> [args]")
        return 1

    subcmd = args[0]

    if subcmd == "dispatch":
        if len(args) < 2:
            print("Usage: nq bg dispatch <prompt>")
            return 1
        prompt = " ".join(args[1:])
        result = nusyq.background.dispatch(prompt)
        print_result(result)
        return 0 if result.success else 1

    elif subcmd == "status":
        task_id = args[1] if len(args) > 1 else None
        result = nusyq.background.status(task_id)
        print_result(result)
        return 0 if result.success else 1

    elif subcmd == "list":
        status_filter = args[1] if len(args) > 1 else None
        result = nusyq.background.list_tasks(status_filter)
        print_result(result)
        return 0 if result.success else 1

    elif subcmd == "process":
        limit = 1
        if len(args) > 1:
            try:
                limit = int(args[1])
            except ValueError:
                print(f"Invalid count: {args[1]}, using 1")

        print(f"🔄 Processing up to {limit} queued tasks...")
        if limit == 1:
            result = nusyq.background.process_one()
        else:
            result = nusyq.background.process_batch(limit)
        print_result(result)
        return 0 if result.success else 1

    elif subcmd == "run":
        # Soft-runtime controlled queue processing loop.
        # Defaults: 4h max, batch size 3, stop when queue empties.
        import time

        duration_seconds = 4 * 60 * 60
        batch_size = 3
        target_completions = None
        sleep_seconds = 2.0
        max_failures = 5
        json_mode = False

        i = 1
        while i < len(args):
            arg = args[i]
            if arg == "--hours" and i + 1 < len(args):
                i += 1
                try:
                    duration_seconds = max(60, int(float(args[i]) * 3600))
                except ValueError:
                    print(f"Invalid --hours value: {args[i]}")
                    return 1
            elif arg == "--minutes" and i + 1 < len(args):
                i += 1
                try:
                    duration_seconds = max(60, int(float(args[i]) * 60))
                except ValueError:
                    print(f"Invalid --minutes value: {args[i]}")
                    return 1
            elif arg == "--batch" and i + 1 < len(args):
                i += 1
                try:
                    batch_size = max(1, int(args[i]))
                except ValueError:
                    print(f"Invalid --batch value: {args[i]}")
                    return 1
            elif arg == "--target-completions" and i + 1 < len(args):
                i += 1
                try:
                    target_completions = max(1, int(args[i]))
                except ValueError:
                    print(f"Invalid --target-completions value: {args[i]}")
                    return 1
            elif arg == "--sleep" and i + 1 < len(args):
                i += 1
                try:
                    sleep_seconds = max(0.0, float(args[i]))
                except ValueError:
                    print(f"Invalid --sleep value: {args[i]}")
                    return 1
            elif arg == "--max-failures" and i + 1 < len(args):
                i += 1
                try:
                    max_failures = max(1, int(args[i]))
                except ValueError:
                    print(f"Invalid --max-failures value: {args[i]}")
                    return 1
            elif arg == "--json":
                json_mode = True
            else:
                print(f"Unknown option: {arg}")
                print(
                    "Usage: nq bg run [--hours N|--minutes N] [--batch N] "
                    "[--target-completions N] [--sleep SECONDS] [--max-failures N] [--json]"
                )
                return 1
            i += 1

        status_start = nusyq.background.status()
        if not status_start.success:
            print_result(status_start)
            return 1

        start_counts = status_start.data.get("status_counts", {})
        start_completed = int(start_counts.get("completed", 0))
        start_queued = int(start_counts.get("queued", 0))

        started_at = time.time()
        deadline = started_at + duration_seconds

        total_processed = 0
        total_succeeded = 0
        total_failed = 0
        loops = 0
        consecutive_failures = 0
        stop_reason = "time_budget_reached"

        if not json_mode:
            print("🚀 Background run mode")
            print(f"   Budget: {duration_seconds}s")
            print(f"   Batch size: {batch_size}")
            print(f"   Queue at start: {start_queued}")
            if target_completions:
                print(f"   Target completions: {target_completions}")

        while time.time() < deadline:
            status_now = nusyq.background.status()
            if not status_now.success:
                stop_reason = "status_error"
                break

            counts = status_now.data.get("status_counts", {})
            queued_now = int(counts.get("queued", 0))
            if queued_now <= 0:
                stop_reason = "queue_empty"
                break

            process_count = min(batch_size, queued_now)
            result = nusyq.background.process_batch(process_count)
            loops += 1
            if not result.success:
                consecutive_failures += 1
                total_failed += process_count
                if not json_mode:
                    print(f"   loop#{loops}: process error ({result.error})")
            else:
                data = result.data or {}
                processed = int(data.get("processed", 0))
                succeeded = int(data.get("succeeded", 0))
                failed = int(data.get("failed", 0))
                total_processed += processed
                total_succeeded += succeeded
                total_failed += failed
                consecutive_failures = 0 if succeeded > 0 else (consecutive_failures + 1)
                if not json_mode:
                    print(
                        f"   loop#{loops}: processed={processed} "
                        f"succeeded={succeeded} failed={failed} queued={queued_now}"
                    )

            if target_completions and total_succeeded >= target_completions:
                stop_reason = "target_completions_reached"
                break

            if consecutive_failures >= max_failures:
                stop_reason = "max_failures_reached"
                break

            if sleep_seconds:
                time.sleep(sleep_seconds)

        elapsed_seconds = int(max(0.0, time.time() - started_at))
        status_end = nusyq.background.status()
        end_counts = status_end.data.get("status_counts", {}) if status_end.success else {}
        end_completed = int(end_counts.get("completed", 0))
        end_queued = int(end_counts.get("queued", 0))

        report = {
            "stop_reason": stop_reason,
            "elapsed_seconds": elapsed_seconds,
            "loops": loops,
            "budget_seconds": duration_seconds,
            "batch_size": batch_size,
            "target_completions": target_completions,
            "start": {
                "queued": start_queued,
                "completed": start_completed,
            },
            "run": {
                "processed": total_processed,
                "succeeded": total_succeeded,
                "failed": total_failed,
            },
            "end": {
                "queued": end_queued,
                "completed": end_completed,
            },
            "delta": {
                "completed": end_completed - start_completed,
                "queued": end_queued - start_queued,
            },
        }

        if json_mode:
            print(json.dumps(report, indent=2))
        else:
            print("\n📊 Run summary")
            print(json.dumps(report, indent=2))

        # Return success unless infrastructure status itself failed.
        if stop_reason in {"status_error"}:
            return 1
        return 0

    else:
        print(f"Unknown bg subcommand: {subcmd}")
        return 1


