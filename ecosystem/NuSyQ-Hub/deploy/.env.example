# Example environment variables for deploy/ compose files
# Copy to deploy/.env (do NOT commit secrets) and update values as needed.

# ----------------------------------------
# CREDENTIALS (REQUIRED — no defaults)
# ----------------------------------------
# Set strong passwords. Compose will fail to start if these are missing.
POSTGRES_PASSWORD=change-me-strong-password
REDIS_PASSWORD=change-me-strong-password
GRAFANA_PASSWORD=change-me-strong-password

# ----------------------------------------
# DATABASE
# ----------------------------------------
POSTGRES_USER=nusyq
POSTGRES_DB=nusyq

# ----------------------------------------
# APPLICATION
# ----------------------------------------
PYTHONUNBUFFERED=1

# ----------------------------------------
# PORTS (override if needed)
# ----------------------------------------
APP_PORT=5000
DB_PORT=5432
REDIS_PORT=6379
OLLAMA_MOCK_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
