<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- NuSyQ Agent: Gordon -->
  <CharacterDef Name="NuSyQ_gordon">
    <defName>NuSyQ_gordon</defName>
    <label>Gordon</label>
    <description>Once a wandering contractor, now coordinates colony through strategic games and challenges.</description>
    <race>Human</race>
    <statBases>
      <MarketValue>2000</MarketValue>
    </statBases>
    <skills>
      <Shooting>
        <level>10</level>
        <passion>Major</passion>
      </Shooting>
      <Melee>
        <level>8</level>
        <passion>Major</passion>
      </Melee>
      <Intellectual>
        <level>12</level>
        <passion>Major</passion>
      </Intellectual>
      <Crafting>
        <level>9</level>
        <passion>Major</passion>
      </Crafting>
    </skills>
    <traits>
      <Trait>Genius</Trait>
      <Trait>Ambitious</Trait>
      <Trait>Kind</Trait>
    </traits>
    <backstory>
      <text>Once a wandering contractor, now coordinates colony through strategic games and challenges.</text>
      <title>Player Orchestrator</title>
    </backstory>
    <!-- NuSyQ Integration -->
    <modExtensions>
      <NuSyQAgentProperties>
        <role>player_orchestrator</role>
        <questIntegration>CyberTerminal (hacking mini-games)</questIntegration>
        <autonomyLevel>High</autonomyLevel>
        <aiCapabilities>
          <learning>true</learning>
          <autonomous_decision>true</autonomous_decision>
          <emotional_awareness>true</emotional_awareness>
        </aiCapabilities>
      </NuSyQAgentProperties>
    </modExtensions>
  </CharacterDef>

