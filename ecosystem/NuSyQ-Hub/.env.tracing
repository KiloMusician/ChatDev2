# OpenTelemetry Configuration
# Use console exporter instead of OTLP when trace service (Jaeger) isn't running
# This prevents connection errors to localhost:4318

OTEL_TRACES_EXPORTER=console
OTEL_SERVICE_NAME=nusyq-hub

# To enable OTLP export when trace service is running, change to:
# OTEL_TRACES_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
