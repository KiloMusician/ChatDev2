#!/bin/bash
# ecoscan — NuSyQ ecosystem quick health check
# Usage: ./ecoscan [--json]

JSON_MODE=0
[[ "$1" == "--json" ]] && JSON_MODE=1

BASE="http://localhost:6400"

probe() {
  local label="$1" url="$2"
  local code
  code=$(curl -o /dev/null -s -w "%{http_code}" --max-time 2 "$url" 2>/dev/null)
  if [[ "$code" == "200" ]]; then
    echo -e "  \033[32m✓\033[0m  $label"
  else
    echo -e "  \033[31m✗\033[0m  $label  (HTTP $code)"
  fi
}

if [[ $JSON_MODE -eq 1 ]]; then
  curl -s "$BASE/api/bridge/manifest" 2>/dev/null | python3 -m json.tool 2>/dev/null
  exit 0
fi

echo ""
echo "  \033[1;36mNuSyQ EcoScan\033[0m — $(date '+%Y-%m-%d %H:%M:%S')"
echo "  ─────────────────────────────────"

probe "ChatDev API     :6400"  "$BASE/health"
probe "Bridge manifest :6400"  "$BASE/api/bridge/manifest"
probe "Orchestrator    :6400"  "$BASE/api/orchestrator/status"
probe "Dev-Mentor      :8008"  "http://localhost:8008/api/manifest"
probe "CONCEPT_SAMURAI :3002"  "http://localhost:3002/"
probe "Quests endpoint :6400"  "$BASE/api/bridge/quests"

echo ""
echo "  \033[1mOrchestrator cycle count:\033[0m"
curl -s "$BASE/api/orchestrator/status" 2>/dev/null \
  | python3 -c "
import sys, json
d = json.load(sys.stdin)
orch = d.get('orchestrator', d)
agents = d.get('agents', [])
tools = d.get('tools', [])
cycle = orch.get('last_cycle', '?')
print(f'    cycles={cycle}, agents={len(agents)}, tools={len(tools)}')
" 2>/dev/null \
  || echo "    (orchestrator not reachable)"

echo ""
echo "  \033[1mDev-Mentor quests:\033[0m"
curl -s "$BASE/api/bridge/quests" 2>/dev/null \
  | python3 -c "import sys,json; d=json.load(sys.stdin); print(f'    total={d.get(\"total\",\"?\")}, categories={d.get(\"categories\",\"?\")}, synced_to_memory={d.get(\"synced\",False)}')" 2>/dev/null \
  || echo "    (not reachable)"

echo ""
