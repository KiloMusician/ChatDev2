'''
Module containing task management functions.
'''
from storage import load_tasks, save_tasks
def add_task(task):
    tasks = load_tasks()
    tasks.append({'id': len(tasks) + 1, 'description': task})
    save_tasks(tasks)
    print(f'Task added: {task}')
def list_tasks():
    tasks = load_tasks()
    if not tasks:
        print('No tasks found.')
    else:
        for task in tasks:
            print(f'{task["id"]}: {task["description"]}')
def delete_task(task_id):
    tasks = load_tasks()
    tasks = [t for t in tasks if t['id'] != task_id]
    save_tasks(tasks)
    print(f'Task {task_id} deleted.')
